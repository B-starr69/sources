{
  "id": "novelfire",
  "url": "https://novelfire.net",
  "cover_url_pattern": "https://novelfire.net/",
  "name": "NovelFire",
  "icon_url": null,
  "description": "Novel reading platform with CSS-based structure",
  "config": {
    "script_path": "sources/novelfire/index.js",
    "default_format": "web_novel",
    "home": {
      "fetch": {
        "type": "js",
        "js_function": "fetchHome"
      },
      "parse": {
        "engine": "js",
        "js_function": "parseHome"
      }
    },
    "details": {
      "fetch": {
        "type": "js",
        "js_function": "fetchBookDetails"
      },
      "parse": {
        "engine": "js",
        "js_function": "parseBookDetails"
      }
    },
    "chapter": {
      "fetch": {
        "type": "js",
        "js_function": "fetchChapterContent"
      },
      "parse": {
        "engine": "js",
        "js_function": "parseChapterContent"
      }
    },
    "chapters_list": {
      "fetch": {
        "type": "js",
        "js_function": "fetchChaptersList"
      },
      "parse": {
        "engine": "js",
        "js_function": "parseChapters"
      }
    },
    "search": {
      "fetch": {
        "type": "js",
        "js_function": "fetchSearch"
      },
      "parse": {
        "engine": "js",
        "js_function": "parseSearch"
      }
    },
    "genres": []
  }
}
