{
  "id": "novelfire",
  "url": "https://novelfire.net",
  "cover_url_pattern": "https://novelfire.net/",
  "name": "NovelFire",
  "icon_url": null,
  "description": "Novel reading platform with CSS-based structure",
  "config": {
    "script_path": "sources/novelfire/index.js",
    "home": {
      "fetch": {
        "type": "native",
        "url": "https://novelfire.net/home"
      },
      "parse": {
        "engine": "js",
        "js_function": "parseHome"
      }
    },
    "details": {
      "fetch": {
        "type": "native",
        "url": ""
      },
      "parse": {
        "engine": "js",
        "js_function": "parseBookDetails"
      }
    },
    "chapter": {
      "fetch": {
        "type": "native",
        "url": ""
      },
      "parse": {
        "engine": "js",
        "js_function": "parseChapterContent"
      }
    },
    "chapters_list": {
      "fetch": {
        "type": "native",
        "url": ""
      },
      "parse": {
        "engine": "js",
        "js_function": "parseChapters"
      }
    },
    "search": {
      "fetch": {
        "type": "native",
        "url_pattern": "https://novelfire.net/ajax/searchLive?keyword={keyword}&type=title",
        "strategy": "single"
      },
      "parse": {
        "engine": "js",
        "js_function": "parseSearch"
      }
    },
    "genres": []
  }
}